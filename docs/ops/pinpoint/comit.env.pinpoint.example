# existing Comit runtime values
SPRING_PROFILES_ACTIVE=staging

# Pinpoint agent injection
JAVA_OPTS=-javaagent:/opt/pinpoint-agent/pinpoint-bootstrap-3.0.5.jar \
  -Dpinpoint.agentId=comit-backend-sidowi-01 \
  -Dpinpoint.applicationName=comit-backend \
  -Dpinpoint.container \
  -Dpinpoint.profiler.transport.module=GRPC \
  -Dpinpoint.profiler.collector.ip=pinpoint-collector \
  -Dpinpoint.profiler.transport.grpc.collector.ip=pinpoint-collector \
  -Dpinpoint.profiler.transport.grpc.agent.collector.port=9991 \
  -Dpinpoint.profiler.transport.grpc.stat.collector.port=9992 \
  -Dpinpoint.profiler.transport.grpc.span.collector.port=9993

# optional rollout note
# - 첫 rollout에서는 sampling 설정을 기본값으로 두고,
#   trace volume이 너무 많을 때만 별도 sampling 옵션을 추가한다.
